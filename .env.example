# ── Telegram Bot ────────────────────────────────────────────
# Required. Get these from @BotFather and @userinfobot on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
AUTHORIZED_USER_ID=your_telegram_user_id

# ── OpenCode Server ─────────────────────────────────────────
# Optional. Defaults shown below.
# OPENCODE_SERVER_URL=http://127.0.0.1:4097
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=

# ── Voice Transcription (OpenAI Whisper) ────────────────────
# Required if you want to use voice messages (F3 feature).
# OPENAI_API_KEY=sk-your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Feature Flags ───────────────────────────────────────────
# Control notification verbosity. All default to false (quiet mode).
# SHOW_TOOL_CALLS=false        # Show individual tool call notifications
# SHOW_THINKING=false           # Show reasoning/thinking text as blockquote
# SHOW_TOKENS=false             # Show token usage in completion notifications

# ── Logging ─────────────────────────────────────────────────
# LOG_LEVEL=info                # debug | info | warn | error
